<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/theme-head') %>
  <title>Расписание — <%= className %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <main class="main">
    <div class="page-head">
      <div>
        <h1 class="page-title">Расписание класса <%= className %></h1>
        <p class="page-subtitle">Учитель: <strong><%= classInfo.teacher %></strong> · Кабинет: <strong><%= classInfo.room %></strong></p>
      </div>
      <div class="page-actions">
        <a href="/class/<%= encodeURIComponent(className) %>" class="btn btn-outline">Назад в дневник</a>
        <a href="/class/<%= encodeURIComponent(className) %>/grades" class="btn btn-primary">Оценки</a>
      </div>
    </div>

    <% if (teacherMode) { %>
    <div class="banner banner-primary">Учительский режим включен. Здесь можно добавлять и редактировать уроки.</div>
    <% } else { %>
    <div class="banner banner-muted">Режим просмотра. Учительский доступ доступен после входа из главного меню.</div>
    <% } %>

    <% if (teacherMode) { %>
    <div class="card form-card">
      <h2>Добавить урок</h2>
      <form method="post" action="/class/<%= encodeURIComponent(className) %>/schedule/add">
        <div class="form-row">
          <div class="form-group">
            <label>День</label>
            <select name="day" required>
              <% dayKeys.forEach(function(d) { %>
              <option value="<%= d %>"><%= DAYS[d] %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>Время</label>
            <input type="time" name="time" value="08:30" required>
          </div>
          <div class="form-group">
            <label>Предмет</label>
            <select name="subject" required>
              <% subjects.forEach(function(s) { %>
              <option value="<%= s %>"><%= s %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>Кабинет</label>
            <input type="text" name="room" value="<%= classInfo.room %>" placeholder="<%= classInfo.room %>">
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Добавить урок</button>
      </form>
    </div>
    <% } %>

    <% dayKeys.forEach(function(day) { %>
    <div class="card day-block">
      <div class="day-title"><%= DAYS[day] %></div>
      <% const lessons = schedule[day] || []; %>
      <% if (lessons.length) { %>
        <% lessons.forEach(function(l, idx) { %>
          <% if (teacherMode) { %>
          <form method="post" action="/class/<%= encodeURIComponent(className) %>/schedule/update" class="lesson-edit-form">
            <input type="hidden" name="day" value="<%= day %>">
            <input type="hidden" name="index" value="<%= idx %>">
            <div class="form-row lesson-edit-row">
              <div class="form-group">
                <input type="time" name="time" value="<%= l.time %>" required>
              </div>
              <div class="form-group">
                <input type="text" name="subject" value="<%= l.subject %>" required>
              </div>
              <div class="form-group">
                <input type="text" name="room" value="<%= l.room %>" placeholder="Кабинет">
              </div>
              <span class="lesson-teacher-fixed"><%= l.teacher %></span>
              <button type="submit" class="btn btn-sm">Сохранить</button>
            </div>
          </form>
          <form method="post" action="/class/<%= encodeURIComponent(className) %>/schedule/remove" style="display:inline;margin-bottom:0.5rem">
            <input type="hidden" name="day" value="<%= day %>">
            <input type="hidden" name="index" value="<%= idx %>">
            <button type="submit" class="btn btn-sm btn-danger-outline" onclick="return confirm('Удалить этот урок?')">Удалить</button>
          </form>
          <% } else { %>
          <div class="lesson-row">
            <span class="lesson-time"><%= l.time %></span>
            <span><strong><%= l.subject %></strong></span>
            <span class="lesson-room">каб. <%= l.room %></span>
            <span class="lesson-teacher"><%= l.teacher %></span>
          </div>
          <% } %>
        <% }); %>
      <% } else { %>
      <p class="empty-state">Нет уроков</p>
      <% } %>
    </div>
    <% }); %>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
