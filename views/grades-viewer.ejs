<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/theme-head') %>
  <title>Оценки</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <main class="main">
    <h1 class="page-title">Журнал оценок</h1>
    <p class="page-subtitle"><%= studentName %> — только просмотр</p>
    <p class="readonly-banner">Изменять оценки может только учитель</p>

    <% Object.keys(bySubject).forEach(function(subject) { %>
    <div class="card" style="margin-bottom:1.25rem">
      <h2><%= subject %> <span class="avg-pill">средний: <%= averages[subject] %></span></h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Оценка</th><th>Тип работы</th><th>Дата</th><th>Комментарий</th></tr>
          </thead>
          <tbody>
            <% bySubject[subject].sort(function(a,b) { return b.date.localeCompare(a.date); }).forEach(function(g) { %>
            <tr>
              <td><span class="grade-badge grade-<%= g.grade %>"><%= g.grade %></span></td>
              <td><%= g.type %></td>
              <td><%= g.date %></td>
              <td><%= g.comment || '—' %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <% }); %>

    <% if (!Object.keys(bySubject).length) { %>
    <div class="card empty-state">Оценок пока нет</div>
    <% } %>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
