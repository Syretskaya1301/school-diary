<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Вход — Электронный дневник</title>
  <%- include('partials/theme-head') %>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="login-page">
    <div class="login-top-bar">
      <%- include('partials/theme-toggle') %>
    </div>
    <div class="login-card">
      <h1>📚 Электронный дневник</h1>
      <p class="subtitle"><%= school.name %> · класс <%= school.class %></p>
      <p class="subtitle-small">Классный руководитель: <%= school.teacher %></p>

      <% if (error) { %>
      <div class="alert-error"><%= error %></div>
      <% } %>

      <form method="post" action="/login" id="loginForm">
        <div class="form-group">
          <label for="role">Категория</label>
          <select id="role" name="role" required>
            <option value="teacher">Учитель</option>
            <option value="student">Ученик</option>
            <option value="parent">Родитель</option>
          </select>
        </div>

        <div class="form-group" id="studentSelect" style="display:none">
          <label for="studentName">Ученик класса <%= school.class %></label>
          <select id="studentName" name="studentName">
            <% students.forEach(function(s) { %>
            <option value="<%= s.name %>"><%= s.name %></option>
            <% }); %>
          </select>
        </div>

        <div class="form-group" id="parentSelect" style="display:none">
          <label for="childName">Ваш ребёнок</label>
          <select id="childName" name="childName">
            <% students.forEach(function(s) { %>
            <option value="<%= s.name %>"><%= s.name %></option>
            <% }); %>
          </select>
        </div>

        <div class="form-group">
          <label for="password">Пароль</label>
          <input type="password" id="password" name="password" required placeholder="••••" autocomplete="current-password">
        </div>
        <button type="submit" class="btn btn-primary">Войти</button>
      </form>

      <div class="hint-box">
        <strong>Пароли:</strong> учитель <code>111</code> · ученик <code>222</code> · родитель <code>333</code><br>
        <span class="hint-muted">В классе <%= students.length %> учеников · один учитель по всем предметам</span>
      </div>
    </div>
  </div>
  <script src="/js/theme.js"></script>
  <script>
    const role = document.getElementById('role');
    const studentSelect = document.getElementById('studentSelect');
    const parentSelect = document.getElementById('parentSelect');
    const studentName = document.getElementById('studentName');
    const childName = document.getElementById('childName');

    function updateFields() {
      const v = role.value;
      studentSelect.style.display = v === 'student' ? 'block' : 'none';
      parentSelect.style.display = v === 'parent' ? 'block' : 'none';
      studentName.required = v === 'student';
      childName.required = v === 'parent';
    }
    role.addEventListener('change', updateFields);
    updateFields();
  </script>
</body>
</html>
