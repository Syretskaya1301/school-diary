<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Пропуски</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <main class="main">
    <h1 class="page-title">Учёт пропусков</h1>
    <p class="page-subtitle"><%= user.role === 'student' ? user.name : 'Все ученики' %></p>

    <div class="card">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <% if (user.role !== 'student') { %><th>Ученик</th><% } %>
              <th>Дата</th><th>Причина</th><th>Статус</th>
            </tr>
          </thead>
          <tbody>
            <% records.forEach(function(r) { %>
            <tr>
              <% if (user.role !== 'student') { %><td><%= r.student %></td><% } %>
              <td><%= r.date %></td>
              <td><%= r.reason %></td>
              <td>
                <% if (r.excused) { %>
                <span class="badge badge-success">Уважительная</span>
                <% } else { %>
                <span class="badge badge-muted">Неуважительная</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% if (!records.length) { %>
      <p class="empty-state">Записей о пропусках нет</p>
      <% } %>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
