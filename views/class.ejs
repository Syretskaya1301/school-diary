<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/theme-head') %>
  <title>Дневник класса <%= classInfo.name %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <main class="main">
    <div class="page-head">
      <div>
        <h1 class="page-title">Дневник класса <%= classInfo.name %></h1>
        <p class="page-subtitle">Учитель: <strong><%= classInfo.teacher %></strong> · Кабинет: <strong><%= classInfo.room %></strong></p>
      </div>
      <div class="page-actions">
        <a href="/class/<%= encodeURIComponent(classInfo.name) %>/schedule" class="btn btn-outline">Расписание</a>
        <a href="/class/<%= encodeURIComponent(classInfo.name) %>/grades" class="btn btn-primary">Оценки</a>
      </div>
    </div>

    <% if (teacherMode) { %>
    <div class="banner banner-primary">Учительский режим — вы можете редактировать расписание и ставить оценки в этом классе.</div>
    <% } else { %>
    <div class="banner banner-muted">Просмотр класса. Чтобы редактировать, войдите как учитель на главной странице или внизу.</div>
    <% } %>

    <div class="grid grid-3 metric-row">
      <div class="metric-card">
        <div class="metric-title">Учеников</div>
        <div class="metric-value"><%= classInfo.students.length %></div>
      </div>
      <div class="metric-card">
        <div class="metric-title">Средний балл класса</div>
        <div class="metric-value"><%= Object.keys(averages).length ? (Object.values(averages).reduce((sum, v) => sum + parseFloat(v), 0) / Object.values(averages).length).toFixed(2) : '—' %></div>
      </div>
      <div class="metric-card">
        <div class="metric-title">Оценок в журнале</div>
        <div class="metric-value"><%= grades.length %></div>
      </div>
    </div>

    <div class="grid grid-2">
      <div class="card">
        <h2>Расписание сегодня — <%= todayName %></h2>
        <% if (todayLessons.length) { %>
          <% todayLessons.forEach(function(lesson) { %>
            <div class="lesson-row">
              <span class="lesson-time"><%= lesson.time %></span>
              <span><strong><%= lesson.subject %></strong></span>
              <span class="lesson-room">каб. <%= lesson.room %></span>
              <span class="lesson-teacher"><%= lesson.teacher %></span>
            </div>
          <% }); %>
        <% } else { %>
          <p class="empty-state">Сегодня занятий нет.</p>
        <% } %>
        <p style="margin-top:1rem"><a href="/class/<%= encodeURIComponent(classInfo.name) %>/schedule">Полное расписание →</a></p>
      </div>

      <div class="card">
        <h2>Средний балл по предметам</h2>
        <% if (Object.keys(averages).length) { %>
        <div class="grid grid-2" style="gap:0.75rem;">
          <% Object.keys(averages).forEach(function(subject) { %>
          <div class="stat-card">
            <div class="number"><%= averages[subject] %></div>
            <div class="label"><%= subject %></div>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <p class="empty-state">Оценок пока нет.</p>
        <% } %>
      </div>
    </div>

    <div class="card">
      <h2>Сводка по ученикам</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>#</th><th>Ученик</th><th>Средний балл</th><th>Последняя оценка</th><th>Последняя дата</th></tr>
          </thead>
          <tbody>
            <% studentStats.forEach(function(stat, index) { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= stat.student %></td>
              <td><%= stat.average %></td>
              <td><%= stat.lastGrade %></td>
              <td><%= stat.lastDate || '—' %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <% if (!teacherMode) { %>
    <div class="card">
      <h2>Учительский вход для редактирования</h2>
      <p>Если вы учитель этого класса, войдите на главной странице, чтобы получить доступ к редактированию расписания и оценок.</p>
      <p><a href="/" class="btn btn-primary">На главную</a></p>
    </div>
    <% } %>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
